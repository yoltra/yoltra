/**
 * Version policies for the Yoltra monorepo.
 * Docs: https://rushjs.io/pages/maintainer/publishing/
 */
[
  {
    /**
     * The product suite versions in lockstep: @yoltra/core, @yoltra/react, and
     * every @yoltra/devtools-* library always share one version and bump
     * together. This is the version that `rush version --bump` moves.
     *
     * We stay pre-1.0 (0.x) until the APIs are stable. In 0.x semver, a breaking
     * change is a MINOR bump, so `nextBump` is "minor" (0.1.0 -> 0.2.0). Set it
     * to "patch" for a fix-only release.
     *
     * NOTE: @yoltra/devtools-ext (browser-extension app) and @yoltra/eslint-config-*
     * (independent tooling) are intentionally NOT in this policy.
     */
    "definitionName": "lockStepVersion",
    "policyName": "yoltra",
    "version": "0.2.0",
    "nextBump": "minor"
  },
  {
    /**
     * @yoltra/ds versions independently of the product suite. It is a design
     * system whose release cadence is driven by its own changes, not by core /
     * react / devtools, so it uses `individualVersion` and self-versions from
     * its own package.json + change files (`rush change`) — the suite's
     * `rush version --bump` never moves it.
     */
    "definitionName": "individualVersion",
    "policyName": "ds"
  }
]
