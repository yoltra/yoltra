{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "vite.config.ts"]
}
