{
  "name": "@yoltra/react",
  "version": "0.1.0",
  "description": "React bindings for Yoltra",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "lint": "node ../../tools/repo-tools/bin/repo-eslint.cjs --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "node ../../tools/repo-tools/bin/repo-eslint.cjs --fix",
    "test": "pnpm vitest --coverage --watch=false",
    "test:watch": "vitest --coverage",
    "prepublishOnly": "node ../../common/scripts/copy-license.js",
    "docs": "rushx docs:js && rushx docs:md",
    "docs:md": "pnpm typedoc --options ./typedoc.react.json",
    "docs:js": "pnpm typedoc --options ./typedoc.react.json --json ./.typedoc/react-en.json"
  },
  "license": "MIT",
  "author": {
    "name": "Manu Ramirez <@pixerael>",
    "email": "manu@yoltra.dev"
  },
  "maintainers": [],
  "homepage": "https://yoltra.dev",
  "keywords": [
    "state",
    "store",
    "react",
    "redux-alternative",
    "yoltra"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yoltra/yoltra.git"
  },
  "bugs": {
    "url": "https://github.com/yoltra/yoltra/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "peerDependencies": {
    "@yoltra/core": "^0.8.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@yoltra/core": {
      "optional": false
    }
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@yoltra/core": "workspace:^0.1.0",
    "@eslint/js": "^9.30.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/react-dom": "^19.1.6",
    "@types/react": "^19.1.8",
    "@types/node": "^24.0.12",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "vite-plugin-banner": "0.8.1",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "jsdom": "^24.0.0",
    "react-dom": "19.1.1",
    "react": "19.1.1",
    "rollup": "^4.16.0",
    "typescript-eslint": "^8.35.1",
    "typescript": "5.9.3",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "4.9.0",
    "typedoc-plugin-localization": "3.0.6",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^4.3.2",
    "vite": "^7.1.11",
    "vitest": "3.2.4"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
