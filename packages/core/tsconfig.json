{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["src", "vitest.setup.ts", "tests/vite-env.d.ts"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "tests",
    "src/**/*.test.ts",
    "tests/**/*.test.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
