{
  "name": "@yoltra/core",
  "version": "0.1.0",
  "description": "A modern predictable state container built on the idea of channels, events, and payloads, giving you strongly typed, expressive actions",
  "scripts": {
    "dev": "vite",
    "lint": "node ../../tools/repo-tools/bin/repo-eslint.cjs --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "node ../../tools/repo-tools/bin/repo-eslint.cjs --fix",
    "test": "pnpm vitest --coverage --watch=false",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tools": "tsc -p tsconfig.tools.json --noEmit",
    "preview": "vite preview",
    "prepublishOnly": "node ../../common/scripts/copy-license.js",
    "docs": "rushx docs:js && rushx docs:md",
    "docs:md": "pnpm typedoc --options ./typedoc.core.json",
    "docs:js": "pnpm typedoc --options ./typedoc.core.json --json ./.typedoc/core-en.json"
  },
  "license": "MIT",
  "author": {
    "name": "Manu Ramirez <@pixerael>",
    "email": "manu@yoltra.dev"
  },
  "maintainers": [],
  "homepage": "https://yoltra.dev",
  "keywords": [
    "state",
    "store",
    "react",
    "redux-alternative",
    "yoltra"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yoltra/yoltra.git"
  },
  "bugs": {
    "url": "https://github.com/yoltra/yoltra/issues"
  },
  "main": "dist/yoltra.cjs.js",
  "module": "dist/yoltra.esm.js",
  "types": "dist/types/index.d.ts",
  "unpkg": "dist/yoltra.umd.js",
  "jsdelivr": "dist/yoltra.umd.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/yoltra.esm.js",
      "require": "./dist/yoltra.cjs.js",
      "default": "./dist/yoltra.esm.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@yoltra/repo-tools": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.12",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "4.9.0",
    "typedoc-plugin-localization": "3.0.6",
    "typescript": "5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-banner": "0.8.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
